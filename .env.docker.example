# Docker Compose environment variables
# Copy this file to .env.docker and fill in values as needed.

# GCP project (uses emulator by default, no real credentials needed)
GOOGLE_CLOUD_PROJECT=demo-test
GOOGLE_CLOUD_PROJECT_ID=demo-test

# Local dev flag (disables cloud logging, enables dev helpers)
LOCAL_DEV=true

# Optional: Redis caching (leave empty to disable)
# REDIS_HOST=
# REDIS_PORT=6379

# Optional: allowed CORS origins (default * in dev)
# ALLOWED_ORIGINS=http://localhost:8501

# Optional: GCS buckets (used when not running against real GCP)
# LOGS_BUCKET_NAME=
# IMAGES_BUCKET_NAME=
# UPLOAD_BUCKET=language-coach-uploads
